{
  "expo": {
    "name": "R3mote",
    "slug": "r3mote",
    "version": "1.0.0",
    "scheme": "r3mote",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/r3mote_logo.png",
    "splash": {
      "image": "./assets/r3mote_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.family.r3mote",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "R3mote discovers and controls TVs on your home network.",
        "NSBonjourServices": [
          "_androidtvremote2._tcp",
          "_adb._tcp"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/r3mote_logo.png",
        "backgroundColor": "#121212"
      },
      "package": "com.family.r3mote",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_MULTICAST_STATE",
        "TRANSMIT_IR",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1112bc5b-f5d0-4105-8b75-67c0a685729f"
      }
    }
  }
}
